# Copy to .env and change passwords before first run:
#   cp .env.example .env

# Guacamole database
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole_user
POSTGRES_PASSWORD=change_me_to_a_strong_password

# Web UI port (friend opens http://<tailscale-ip>:8080/guacamole)
GUACAMOLE_PORT=8080

# Linux user inside rdesktop container (file ownership)
PUID=1000
PGID=1000
TZ=UTC
